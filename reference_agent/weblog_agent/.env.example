# Web Log ReAct Agent LLM configuration
# Copy to reference_agent/weblog_agent/.env or point WEBLOG_AGENT_ENV_FILE to your own file.

# Any OpenAI-compatible Chat Completions endpoint works:
# - OpenAI: https://api.openai.com/v1
# - vLLM: http://localhost:8000/v1
# - LM Studio: http://localhost:1234/v1
# - Ollama OpenAI-compatible: http://localhost:11434/v1
# - internal gateway: https://llm-gateway.example.com/v1
WEBLOG_AGENT_LLM_PROVIDER=openai-compatible
WEBLOG_AGENT_LLM_BASE_URL=http://localhost:1234/v1
WEBLOG_AGENT_LLM_CHAT_COMPLETIONS_PATH=/chat/completions
WEBLOG_AGENT_LLM_MODEL=local-model

# Local LLMs often do not require API keys. Set true for OpenAI/internal gateways.
WEBLOG_AGENT_LLM_REQUIRE_API_KEY=false

# If auth is required, prefer an env var outside this file for secrets:
WEBLOG_AGENT_LLM_API_KEY_ENV=OPENAI_API_KEY
# WEBLOG_AGENT_LLM_API_KEY=do-not-commit-real-secrets
WEBLOG_AGENT_LLM_AUTH_HEADER=Authorization
WEBLOG_AGENT_LLM_AUTH_SCHEME=Bearer

WEBLOG_AGENT_LLM_TEMPERATURE=0.2
WEBLOG_AGENT_LLM_TIMEOUT_SECONDS=45
# Optional additional headers as JSON, e.g. {"X-Tenant":"dev"}
# WEBLOG_AGENT_LLM_EXTRA_HEADERS_JSON={}
