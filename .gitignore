# Generated reference agent outputs
reference_agent/weblog_agent/traces/*.jsonl
reference_agent/weblog_agent/reports/*.md

# Runtime artifacts (generated by backend during execution)
artifacts/frontend-api/analyses/*.json
artifacts/frontend-api/analyses/reports/
artifacts/frontend-api/judge-sessions/*.json
artifacts/frontend-api/reference-runs/traces/
artifacts/frontend-api/reference-runs/reports/
artifacts/frontend-api/*/registry.json

# Python cache
__pycache__/
*.py[cod]
.pytest_cache/

# Local environment / secrets
.env
judgeagent/.env
reference_agent/weblog_agent/.env
judgeagent/reference/agent/weblog_agent/.env
*.env.local
