# Judge Agent Simple configuration
# Copy to `.env` at repo root or `simple/.env` and adjust values.

# Optional file-based config directory override.
# Defaults to `simple/config`.
# JUDGE_CONFIG_DIR=/absolute/path/to/config

# Judge Agent Simple LLM configuration

# Providers:
# - openai: official OpenAI API
# - openai-compatible / compatible: any /v1/chat/completions compatible endpoint
# - local / vllm / lmstudio / ollama / localai / llama-cpp: local OpenAI-compatible endpoints
# - mock: test-only mock provider
# - none: disable LLM and use deterministic fallback
JUDGE_LLM_PROVIDER=openai-compatible

# Model name sent to the chat completions endpoint.
# Examples:
# - OpenAI: gpt-4o-mini
# - vLLM: meta-llama/Llama-3.1-8B-Instruct
# - LM Studio: local model id shown by the server
# - Ollama OpenAI-compatible: llama3.1 or qwen2.5
JUDGE_LLM_MODEL=local-model

# Base URL WITHOUT /chat/completions unless your server requires the full path.
# OpenAI: https://api.openai.com/v1
# vLLM: http://localhost:8000/v1
# LM Studio: http://localhost:1234/v1
# Ollama: http://localhost:11434/v1
JUDGE_LLM_BASE_URL=http://localhost:8000/v1

# API key. For many local servers this can be any non-empty value, e.g. local.
JUDGE_LLM_API_KEY=local

# Optional runtime tuning.
JUDGE_LLM_TIMEOUT_SECONDS=30
JUDGE_LLM_TEMPERATURE=0

# Backward-compatible aliases also supported:
# LLM_PROVIDER, LLM_MODEL, LLM_BASE_URL, LLM_API_KEY
# OPENAI_API_KEY, OPENAI_MODEL, OPENAI_BASE_URL
