{
  "version": 1,
  "default_provider": "auto",
  "default_model": "gpt-4o-mini",
  "providers": {
    "openai": {
      "base_url": "https://api.openai.com/v1",
      "default_model": "gpt-4o-mini",
      "models": ["gpt-4o-mini", "gpt-4.1-mini", "gpt-4.1", "gpt-4o"]
    },
    "openai-compatible": {
      "base_url": "http://localhost:8000/v1",
      "default_model": "local-model",
      "models": ["local-model"]
    },
    "vllm": {
      "base_url": "http://localhost:8000/v1",
      "default_model": "local-model",
      "models": ["local-model", "meta-llama/Llama-3.1-8B-Instruct"]
    },
    "lmstudio": {
      "base_url": "http://localhost:1234/v1",
      "default_model": "local-model",
      "models": ["local-model"]
    },
    "ollama": {
      "base_url": "http://localhost:11434/v1",
      "default_model": "qwen3.5:latest",
      "models": ["qwen3.5:latest", "gemma4:latest", "gemma4:26b"]
    },
    "localai": {
      "base_url": "http://localhost:8000/v1",
      "default_model": "local-model",
      "models": ["local-model"]
    },
    "llama-cpp": {
      "base_url": "http://localhost:8000/v1",
      "default_model": "local-model",
      "models": ["local-model"]
    },
    "mock": {
      "default_model": "mock-llm",
      "models": ["mock-llm"]
    },
    "none": {
      "default_model": "deterministic-fallback",
      "models": ["deterministic-fallback"]
    }
  }
}
